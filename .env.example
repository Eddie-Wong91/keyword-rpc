# Copy this file to .env and fill in real values.

LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=3306
LOCAL_DB_USER=user
LOCAL_DB_PASSWORD=your_user_password
LOCAL_DB_DATABASE=database_name

SIF_DB_HOST=localhost
SIF_DB_PORT=3306
SIF_DB_USER=user
SIF_DB_PASSWORD=your_user_password
SIF_DB_DATABASE=database_name

LINGXING_DB_PORT=3306
LINGXING_DB_USER=user
LINGXING_DB_PASSWORD=your_user_password
LINGXING_DB_DATABASE=database_name

RPC_HOST=0.0.0.0
RPC_PORT=7001
RPC_DEBUG=false
RPC_URL=http://127.0.0.1:7001/rpc

REQUEST_TIMEOUT=60
BATCH_REQUEST_INTERVAL_SECONDS=1
SIF_RETRY_COUNT=10
SIF_RETRY_SLEEP_SECONDS=2

EXCEL_BASE_DIR=C:\rpa\amazon\product_info
LOG_DIR=logs

UUID_RESOURCE_VARIABLE_URL=https://z-commander-api.ai-indeed.com/openAPI/v2/resource-variable/select-resource-variable-by-uuid
UUID_RESOURCE_VARIABLE_UUID=your_uuid
UUID_APP_KEY=your_app_key
UUID_APP_SECRET=your_app_secret

LINGXING_API_BASE_URL=https://xxx.lingxing.com
LINGXING_REFERER=https://xxx.lingxing.com/erp/keywordRanking

SIF_API_BASE_URL=https://www.sif.com
SIF_ORIGIN=https://www.sif.com
SIF_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36
